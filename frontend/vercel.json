{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/*.js": {
      "runtime": "vercel-node@latest"
    }
  },
  "crons": [
    {
      "path": "/api/keep-warm",
      "schedule": "*/10 * * * *"
    }
  ]
}